{
    "name": "nextmigrant/laravel-sendy",
    "description": "A generic Sendy email marketing API client for Laravel",
    "keywords": [
        "nextmigrant",
        "laravel",
        "sendy",
        "email-marketing"
    ],
    "homepage": "https://github.com/nextmigrant/laravel-sendy",
    "license": "proprietary",
    "authors": [
        {
            "name": "NextMigrant",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^10.0||^11.0||^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0||^9.0||^10.0",
        "phpunit/phpunit": "^10.5||^11.0"
    },
    "autoload": {
        "psr-4": {
            "NextMigrant\\Sendy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "NextMigrant\\Sendy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "NextMigrant\\Sendy\\SendyServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}